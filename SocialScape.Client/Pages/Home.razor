@page "/"

<nav>
    <div class="container-main">
        <h2 class="log">
            Name SocialMedia
        </h2>
        <div class="search-bar">
            <i class="uil uil-search"></i>
            <input type="search" placeholder="Search for creators,inspirations, and projects" />
        </div>
        <div class="create">
            <label class="btn-main btn-main-primary" for="create-post">Create Post</label>
            <div class="profile-photo">
                <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
            </div>
        </div>
    </div>
</nav>
<main>
    <div class="container-main">
        <div class="left">
            <a class="profile">
                <div class="profile-photo">
                    <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                </div>
                <div class="handle">
                    <h4>Full Name</h4>
                    <p class="text-muted">@@username</p>
                </div>
            </a>

            <div class="sidebar-main">
                <a class="menu-item active">
                    <span><i class="uil uil-home"></i></span><h3>Home</h3>
                </a>
                <a class="menu-item ">
                    <span><i class="uil uil-compass"></i></span><h3>Explore</h3>
                </a>
                <a class="menu-item ">
                    <span><i class="uil uil-bell" id="notification"><small class="notification-count">9+</small></i></span><h3>Notification</h3>

                    <div class="notification-popup">
                        <div>
                            <div class="profile-photo">
                                <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                            </div>
                            <div class="notifications-body">
                                <b>Keke Benjamin</b> accepted your friend request
                                <small class="text-muted">2 DAYS AGO</small>
                            </div>
                        </div>
                    </div>
                </a>
                <a class="menu-item ">
                    <span><i class="uil uil-envelope-alt" id="message"><small class="notification-count">9+</small></i></span><h3>Message</h3>
                </a>
                <a class="menu-item ">
                    <span><i class="uil uil-bookmark"></i></span><h3>Bookmark</h3>
                </a>
                <a class="menu-item ">
                    <span><i class="uil uil-chart-line"></i></span><h3>Analytics</h3>
                </a>
                <a @onclick="ThemeHandle" class="menu-item ">
                    <span><i class="uil uil-palette"></i></span><h3>Theme</h3>
                </a>
                <a class="menu-item ">
                    <span><i class="uil uil-setting"></i></span><h3>Settings</h3>
                </a>

            </div>
        </div>
        <div class="middle">
            <div class="stories">
                <div class="story">
                    <div class="profile-photo">
                        <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                    </div>
                    <p class="name">Your story</p>
                </div>
                <div class="story">
                    <div class="profile-photo">
                        <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                    </div>
                    <p class="name">Your story</p>
                </div>
                <div class="story">
                    <div class="profile-photo">
                        <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                    </div>
                    <p class="name">Your story</p>
                </div>
                <div class="story">
                    <div class="profile-photo">
                        <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                    </div>
                    <p class="name">Your story</p>
                </div>
                <div class="story">
                    <div class="profile-photo">
                        <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                    </div>
                    <p class="name">Your story</p>
                </div>
                <div class="story">
                    <div class="profile-photo">
                        <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                    </div>
                    <p class="name">Your story</p>
                </div>
                <div class="story">
                    <div class="profile-photo">
                        <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                    </div>
                    <p class="name">Your story</p>
                </div>
            </div>

            <form class="create-post">
                <div class="profile-photo">
                    <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                </div>
                <input type="text" placeholder="What`s on ypur mind, Diana" id="create-post" />
                <input type="submit" value="Post" class="btn-main btn-main-primary" />
            </form>

            <div class="feeds">
                <div class="feed">
                    <div class="head">
                        <div class="user">
                            <div class="profile-photo">
                                <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                            </div>
                            <div class="ingo">
                                <h3>Full Name</h3>
                                <small>15 MINUTES AGO</small>
                            </div>
                            <span class="edit">
                                <i class="uil uil-ellipsis-h"></i>
                            </span>
                        </div>
                    </div>

                    <div class="photo">
                        <img src="https://i.ibb.co/zQBK3YD/feed-5.jpg" />
                    </div>

                    <div class="action-buttons">
                        <div class="interaction-buttons">
                            <span><i class="uil uil-heart"></i></span>
                            <span><i class="uil uil-comment-dots"></i></span>
                            <span><i class="uil uil-share-alt"></i></span>
                        </div>
                        <div class="bookmark">
                            <span><i class="uil uil-bookmark-full"></i></span>
                        </div>
                    </div>

                    <div class="liked-by">
                        <span>
                            <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                        </span>
                        <span>
                            <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                        </span>
                        <span>
                            <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                        </span>
                        <p>Liked by <b>Ernset Achiever</b> and <b>2,323 others  </b></p>
                    </div>

                    <div class="caption">
                        <p>
                            <b>Lana Rose</b>Lorem ipsum dolor sit quisquameus.
                            <span class="harsh-tag">#lifestyle</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
        <div class="right">
            <div class="messages">
                <div class="heading">
                    <h4>Messages</h4><i class="uil uil-edit"></i>
                </div>

                <div class="search-bar">
                    <i class="uil uil-search"></i>

                    <input type="search" placeholder="Search messages" id="message-search" />
                </div>

                <div class="category">
                    <h6 class="active">Primary</h6>

                </div>

                <div class="message">
                    <div class="profile-photo">
                        <img src="https://i.ibb.co/59wCg68/profile-8.jpg" />
                    </div>
                    <div class="message-body">
                        <h5>Edem Quistr</h5>
